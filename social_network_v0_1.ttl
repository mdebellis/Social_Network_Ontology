  owl:members ( sn:Adolescent
                sn:Adult
                sn:Child
              )
] .


[ rdf:type owl:AllDifferent ;
  owl:distinctMembers ( sn:Age_0_To_12
                        sn:Age_13_To_15
                        sn:Age_16_To_17
                        sn:Age_18_And_Over
                      )
] .


[ rdf:type owl:AllDifferent ;
  owl:distinctMembers ( sn:Collaborator_Role
                        sn:Contributor_Role
                        sn:Facilitator_Role
                        sn:Friend_Role
                        sn:Learner_Role
                        sn:Mentee_Role
                        sn:Mentor_Role
