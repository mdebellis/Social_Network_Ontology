@prefix : <https://www.michaeldebellis.com/social_network/> .
@prefix sn: <https://www.michaeldebellis.com/social_network/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix sulo: <https://w3id.org/sulo/> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix big_bro: <https://www.michaeldebellis.com/big_bro/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@base <https://www.michaeldebellis.com/social_network/> .

<https://www.michaeldebellis.com/social_network> rdf:type owl:Ontology ;
                                                  owl:versionIRI <https://www.michaeldebellis.com/social_network/0.1.0> ;
                                                  owl:imports <https://www.michaeldebellis.com/big_bro> ;
                                                  dcterms:created "2026-07-16"^^xsd:date ;
                                                  dcterms:creator <https://orcid.org/0000-0002-8824-9577> ;
                                                  dcterms:description "An initial ontology for representing Social Network participants, multidimensional person classifications, first-class social relationships, relationship-specific roles, interests, expertise, and qualified participation in activities."@en ;
                                                  dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
												  dcterms:rights "Copyright © 2026 Michael DeBellis. Licensed under CC BY 4.0."@en ;
                                                  dcterms:title "Social Network Ontology"@en ;
                                                  vann:preferredNamespacePrefix "sn" ;
                                                  vann:preferredNamespaceUri sn: ;
                                                  rdfs:label "Social Network Ontology"@en ;
                                                  owl:versionInfo "0.1.0" ;
                                                  skos:changeNote "Initial exploratory version to model Social Networks."@en .

#################################################################
#    Object Properties
#################################################################

###  https://www.michaeldebellis.com/social_network/has_activity_participant
sn:has_activity_participant rdf:type owl:ObjectProperty ;
                            owl:inverseOf sn:participates_in_activity ;
                            rdfs:domain prov:Activity ;
                            rdfs:range prov:Agent ;
                            owl:propertyChainAxiom ( sn:has_activity_participation
                                                     prov:agent
                                                   ) ;
                            rdfs:isDefinedBy <https://www.michaeldebellis.com/social_network> ;
                            rdfs:label "has activity participant"@en ;
                            skos:definition "A derived convenience property connecting an activity directly to an agent participating in it."@en ;
                            skos:prefLabel "has activity participant"@en ;
                            skos:scopeNote "This property is inferred from activity participation records and should not be maintained independently."@en .


###  https://www.michaeldebellis.com/social_network/has_activity_participation
sn:has_activity_participation rdf:type owl:ObjectProperty ;
                              rdfs:subPropertyOf prov:qualifiedAssociation ;
                              owl:inverseOf sn:is_activity_participation_in ;
                              rdfs:domain prov:Activity ;
                              rdfs:range sn:Activity_Participation ;
                              rdfs:isDefinedBy <https://www.michaeldebellis.com/social_network> ;
                              rdfs:label "has activity participation"@en ;
                              skos:definition "Connects an activity to a qualified participation by one agent."@en ;
                              skos:prefLabel "has activity participation"@en .


###  https://www.michaeldebellis.com/social_network/has_age_band
sn:has_age_band rdf:type owl:ObjectProperty ;
                owl:inverseOf sn:is_age_band_of ;
                rdf:type owl:FunctionalProperty ;
                rdfs:domain prov:Person ;
                rdfs:range sn:Age_Band ;
                rdfs:isDefinedBy <https://www.michaeldebellis.com/social_network> ;
                rdfs:label "has age band"@en ;
                skos:definition "Connects a person to the person's current privacy-preserving age band."@en ;
                skos:prefLabel "has age band"@en .


###  https://www.michaeldebellis.com/social_network/has_expertise
sn:has_expertise rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf sulo:hasFeature ;
                 owl:inverseOf sn:is_expertise_of ;
                 rdfs:domain prov:Agent ;
                 rdfs:range sn:Expertise ;
                 rdfs:isDefinedBy <https://www.michaeldebellis.com/social_network> ;
                 rdfs:label "has expertise"@en ;
                 skos:definition "Connects an agent to a first-class Expertise capability."@en ;
                 skos:prefLabel "has expertise"@en .


###  https://www.michaeldebellis.com/social_network/has_expertise_subject
sn:has_expertise_subject rdf:type owl:ObjectProperty ;
                         owl:inverseOf sn:is_expertise_subject_of ;
                         rdfs:domain sn:Expertise ;
                         rdfs:range sulo:Object ;
                         rdfs:isDefinedBy <https://www.michaeldebellis.com/social_network> ;
                         rdfs:label "has expertise subject"@en ;
                         skos:definition "Connects an Expertise capability to a topic, ecosystem, resource, or other subject concerning which the agent has expertise."@en ;
                         skos:prefLabel "has expertise subject"@en .


###  https://www.michaeldebellis.com/social_network/has_interest
sn:has_interest rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf sulo:hasFeature ;
                owl:inverseOf sn:is_interest_of ;
                rdfs:domain prov:Agent ;
                rdfs:range sn:Interest ;
                rdfs:isDefinedBy <https://www.michaeldebellis.com/social_network> ;
                rdfs:label "has interest"@en ;
                skos:definition "Connects an agent to a first-class Interest."@en ;
                skos:prefLabel "has interest"@en .


###  https://www.michaeldebellis.com/social_network/has_interest_subject
sn:has_interest_subject rdf:type owl:ObjectProperty ;
                        owl:inverseOf sn:is_interest_subject_of ;
                        rdfs:domain sn:Interest ;
                        rdfs:range sulo:Object ;
                        rdfs:isDefinedBy <https://www.michaeldebellis.com/social_network> ;
                        rdfs:label "has interest subject"@en ;
                        skos:definition "Connects an Interest to a topic, ecosystem, resource, activity-related object, or other subject of interest."@en ;
                        skos:prefLabel "has interest subject"@en .


###  https://www.michaeldebellis.com/social_network/has_relationship_context
sn:has_relationship_context rdf:type owl:ObjectProperty ;
                            owl:inverseOf sn:is_context_for_relationship ;
                            rdfs:domain sn:Social_Relationship ;
                            rdfs:range owl:Thing ;
                            rdfs:isDefinedBy <https://www.michaeldebellis.com/social_network> ;
                            rdfs:label "has relationship context"@en ;
                            skos:definition "Connects a social relationship to a project, activity, ecosystem, topic, location, organization, or other entity that supplies relevant context."@en ;
                            skos:prefLabel "has relationship context"@en ;
                            skos:scopeNote "The broad range is intentional because a relationship may be contextualized by either an object or a process. More specific subproperties can be added when requirements justify them."@en .


###  https://www.michaeldebellis.com/social_network/has_relationship_participant
sn:has_relationship_participant rdf:type owl:ObjectProperty ;
                                rdfs:subPropertyOf sulo:isFeatureOf ;
                                owl:inverseOf sn:participates_in_relationship ;
                                rdfs:domain sn:Social_Relationship ;
                                rdfs:range prov:Agent ;
                                owl:propertyChainAxiom ( sn:has_relationship_participation
                                                         prov:agent
                                                       ) ;
                                rdfs:isDefinedBy <https://www.michaeldebellis.com/social_network> ;
                                rdfs:label "has relationship participant"@en ;
                                skos:definition "A derived convenience property connecting a social relationship directly to an agent participating in it."@en ;
                                skos:prefLabel "has relationship participant"@en ;
                                skos:scopeNote "This property is inferred from relationship participation records. It should not be maintained independently of those records."@en .


###  https://www.michaeldebellis.com/social_network/has_relationship_participation
sn:has_relationship_participation rdf:type owl:ObjectProperty ;
                                  owl:inverseOf sn:is_relationship_participation_in ;
                                  rdfs:domain sn:Social_Relationship ;
                                  rdfs:range sn:Relationship_Participation ;
                                  rdfs:isDefinedBy <https://www.michaeldebellis.com/social_network> ;
                                  rdfs:label "has relationship participation"@en ;
                                  skos:definition "Connects a social relationship to a qualified participation by one agent."@en ;
                                  skos:prefLabel "has relationship participation"@en .


###  https://www.michaeldebellis.com/social_network/is_activity_participation_in
sn:is_activity_participation_in rdf:type owl:ObjectProperty ;
                                rdfs:domain sn:Activity_Participation ;
                                rdfs:range prov:Activity ;
                                rdfs:isDefinedBy <https://www.michaeldebellis.com/social_network> ;
                                rdfs:label "is activity participation in"@en ;
                                skos:definition "Connects a qualified activity participation to the activity in which the agent participates."@en ;
                                skos:prefLabel "is activity participation in"@en .


###  https://www.michaeldebellis.com/social_network/is_age_band_of
sn:is_age_band_of rdf:type owl:ObjectProperty ;
                  rdfs:domain sn:Age_Band ;
                  rdfs:range prov:Person ;
                  rdfs:isDefinedBy <https://www.michaeldebellis.com/social_network> ;
                  rdfs:label "is age band of"@en ;
                  skos:definition "Connects an age band to a person currently classified in that age band."@en ;
                  skos:prefLabel "is age band of"@en .


###  https://www.michaeldebellis.com/social_network/is_context_for_relationship
sn:is_context_for_relationship rdf:type owl:ObjectProperty ;
                               rdfs:domain owl:Thing ;
                               rdfs:range sn:Social_Relationship ;
                               rdfs:isDefinedBy <https://www.michaeldebellis.com/social_network> ;
                               rdfs:label "is context for relationship"@en ;
                               skos:definition "Connects an entity or process to a social relationship for which it supplies context."@en ;
                               skos:prefLabel "is context for relationship"@en .


###  https://www.michaeldebellis.com/social_network/is_expertise_of
sn:is_expertise_of rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf sulo:isFeatureOf ;
                   rdfs:domain sn:Expertise ;
                   rdfs:range prov:Agent ;
                   rdfs:isDefinedBy <https://www.michaeldebellis.com/social_network> ;
                   rdfs:label "is expertise of"@en ;
                   skos:definition "Connects an Expertise capability to the agent who possesses it."@en ;
                   skos:prefLabel "is expertise of"@en .


###  https://www.michaeldebellis.com/social_network/is_expertise_subject_of
sn:is_expertise_subject_of rdf:type owl:ObjectProperty ;
                           rdfs:domain sulo:Object ;
                           rdfs:range sn:Expertise ;
                           rdfs:isDefinedBy <https://www.michaeldebellis.com/social_network> ;
                           rdfs:label "is expertise subject of"@en ;
                           skos:definition "Connects a topic, ecosystem, resource, or other subject to an Expertise capability concerning that subject."@en ;
                           skos:prefLabel "is expertise subject of"@en .


###  https://www.michaeldebellis.com/social_network/is_interest_of
sn:is_interest_of rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf sulo:isFeatureOf ;
                  rdfs:domain sn:Interest ;
                  rdfs:range prov:Agent ;
                  rdfs:isDefinedBy <https://www.michaeldebellis.com/social_network> ;
                  rdfs:label "is interest of"@en ;
                  skos:definition "Connects an Interest to the agent whose interest it represents."@en ;
                  skos:prefLabel "is interest of"@en .


###  https://www.michaeldebellis.com/social_network/is_interest_subject_of
sn:is_interest_subject_of rdf:type owl:ObjectProperty ;
                          rdfs:domain sulo:Object ;
                          rdfs:range sn:Interest ;
                          rdfs:isDefinedBy <https://www.michaeldebellis.com/social_network> ;
                          rdfs:label "is interest subject of"@en ;
                          skos:definition "Connects a topic, ecosystem, resource, or other subject to an Interest concerning that subject."@en ;
                          skos:prefLabel "is interest subject of"@en .


###  https://www.michaeldebellis.com/social_network/is_relationship_participation_in
sn:is_relationship_participation_in rdf:type owl:ObjectProperty ;
                                    rdfs:domain sn:Relationship_Participation ;
                                    rdfs:range sn:Social_Relationship ;
                                    rdfs:isDefinedBy <https://www.michaeldebellis.com/social_network> ;
                                    rdfs:label "is relationship participation in"@en ;
                                    skos:definition "Connects a qualified relationship participation to the social relationship in which it occurs."@en ;
                                    skos:prefLabel "is relationship participation in"@en .


###  https://www.michaeldebellis.com/social_network/participates_in_activity
sn:participates_in_activity rdf:type owl:ObjectProperty ;
                            rdfs:domain prov:Agent ;
                            rdfs:range prov:Activity ;
                            rdfs:isDefinedBy <https://www.michaeldebellis.com/social_network> ;
                            rdfs:label "participates in activity"@en ;
                            skos:definition "A derived convenience property connecting an agent directly to an activity in which the agent participates."@en ;
                            skos:prefLabel "participates in activity"@en .


###  https://www.michaeldebellis.com/social_network/participates_in_relationship
sn:participates_in_relationship rdf:type owl:ObjectProperty ;
                                rdfs:subPropertyOf sulo:hasFeature ;
                                rdfs:domain prov:Agent ;
                                rdfs:range sn:Social_Relationship ;
                                rdfs:isDefinedBy <https://www.michaeldebellis.com/social_network> ;
                                rdfs:label "participates in relationship"@en ;
                                skos:definition "A derived convenience property connecting an agent directly to a social relationship in which the agent participates."@en ;
                                skos:prefLabel "participates in relationship"@en .


#################################################################
#    Data properties
#################################################################

###  https://www.michaeldebellis.com/social_network/relationship_ended_at
sn:relationship_ended_at rdf:type owl:DatatypeProperty ;
                         rdfs:domain sn:Social_Relationship ;
                         rdfs:range xsd:dateTime ;
                         rdfs:isDefinedBy <https://www.michaeldebellis.com/social_network> ;
                         rdfs:label "relationship ended at"@en ;
                         skos:definition "The date and time at which a social relationship ended."@en ;
                         skos:prefLabel "relationship ended at"@en .


###  https://www.michaeldebellis.com/social_network/relationship_started_at
sn:relationship_started_at rdf:type owl:DatatypeProperty ;
                           rdfs:domain sn:Social_Relationship ;
                           rdfs:range xsd:dateTime ;
                           rdfs:isDefinedBy <https://www.michaeldebellis.com/social_network> ;
                           rdfs:label "relationship started at"@en ;
                           skos:definition "The date and time at which a social relationship began."@en ;
                           skos:prefLabel "relationship started at"@en .


#################################################################
#    Classes
#################################################################

###  https://www.michaeldebellis.com/social_network/Activity_Participation
sn:Activity_Participation rdf:type owl:Class ;
                          rdfs:subClassOf prov:Association ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty prov:hadRole ;
                                            owl:allValuesFrom sn:SN_Role
                                          ] ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty prov:hadRole ;
                                            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                            owl:onClass sn:SN_Role
                                          ] ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty prov:agent ;
                                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                            owl:onClass prov:Agent
                                          ] ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty sn:is_activity_participation_in ;
                                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                            owl:onClass prov:Activity
                                          ] ;
                          owl:hasKey ( prov:agent
                                       sn:is_activity_participation_in
                                     ) ;
                          rdfs:isDefinedBy <https://www.michaeldebellis.com/social_network> ;
                          rdfs:label "Activity Participation"@en ;
                          skos:definition "A qualified PROV association connecting one agent to one activity and recording the role or roles held by the agent in that activity."@en ;
                          skos:prefLabel "Activity Participation"@en .


###  https://www.michaeldebellis.com/social_network/Adolescent
sn:Adolescent rdf:type owl:Class ;
              owl:equivalentClass [ owl:intersectionOf ( prov:Person
                                                         [ rdf:type owl:Class ;
                                                           owl:unionOf ( [ rdf:type owl:Restriction ;
                                                                           owl:onProperty sn:has_age_band ;
                                                                           owl:hasValue sn:Age_13_To_15
                                                                         ]
                                                                         [ rdf:type owl:Restriction ;
                                                                           owl:onProperty sn:has_age_band ;
                                                                           owl:hasValue sn:Age_16_To_17
                                                                         ]
                                                                       )
                                                         ]
                                                       ) ;
                                    rdf:type owl:Class
                                  ] ;
              rdfs:subClassOf sn:Person_Classified_By_Life_Stage ;
              rdfs:isDefinedBy <https://www.michaeldebellis.com/social_network> ;
              rdfs:label "Adolescent"@en ;
              skos:definition "A person whose current age band is Age 13 to 15 or Age 16 to 17."@en ;
              skos:prefLabel "Adolescent"@en .


###  https://www.michaeldebellis.com/social_network/Adult
sn:Adult rdf:type owl:Class ;
         owl:equivalentClass [ owl:intersectionOf ( prov:Person
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty sn:has_age_band ;
                                                      owl:hasValue sn:Age_18_And_Over
                                                    ]
                                                  ) ;
                               rdf:type owl:Class
                             ] ;
         rdfs:subClassOf sn:Person_Classified_By_Life_Stage ;
         rdfs:isDefinedBy <https://www.michaeldebellis.com/social_network> ;
         rdfs:label "Adult"@en ;
         skos:definition "A person whose current age band is Age 18 and Over."@en ;
         skos:prefLabel "Adult"@en ;
         skos:scopeNote "This is an application classification based on the selected age band, not a universal claim about legal adulthood in every jurisdiction."@en .


###  https://www.michaeldebellis.com/social_network/Age_Band
sn:Age_Band rdf:type owl:Class ;
            rdfs:subClassOf prov:Entity ,
                            sulo:InformationObject ;
            rdfs:isDefinedBy <https://www.michaeldebellis.com/social_network> ;
            rdfs:label "Age Band"@en ;
            skos:definition "A privacy-preserving controlled category representing a range of current ages."@en ;
            skos:prefLabel "Age Band"@en ;
            skos:scopeNote "Age bands support current-state classification without requiring an exact age."@en .


###  https://www.michaeldebellis.com/social_network/Child
sn:Child rdf:type owl:Class ;
         owl:equivalentClass [ owl:intersectionOf ( prov:Person
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty sn:has_age_band ;
                                                      owl:hasValue sn:Age_0_To_12
                                                    ]
                                                  ) ;
                               rdf:type owl:Class
                             ] ;
         rdfs:subClassOf sn:Person_Classified_By_Life_Stage ;
         rdfs:isDefinedBy <https://www.michaeldebellis.com/social_network> ;
         rdfs:label "Child"@en ;
         skos:definition "A person whose current age band is Age 0 to 12."@en ;
         skos:prefLabel "Child"@en .


###  https://www.michaeldebellis.com/social_network/Citizen_Scientist
sn:Citizen_Scientist rdf:type owl:Class ;
                     rdfs:subClassOf sn:Person_Classified_By_Practice ;
                     rdfs:isDefinedBy <https://www.michaeldebellis.com/social_network> ;
                     rdfs:label "Citizen Scientist"@en ;
                     skos:definition "A person who contributes to scientific inquiry outside or alongside a conventional professional scientific position."@en ;
                     skos:prefLabel "Citizen Scientist"@en ;
                     skos:scopeNote "Citizen Scientist is not asserted as a subclass of Scientist because we may include participants who make valuable scientific contributions without adopting a professional or disciplinary scientist identity."@en .


###  https://www.michaeldebellis.com/social_network/Collaboration_Relationship
sn:Collaboration_Relationship rdf:type owl:Class ;
                              rdfs:subClassOf sn:Social_Relationship ,
                                              [ rdf:type owl:Restriction ;
                                                owl:onProperty sn:has_relationship_participation ;
                                                owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
                                                owl:onClass sn:Collaborator_Participation
                                              ] ;
                              rdfs:isDefinedBy <https://www.michaeldebellis.com/social_network> ;
                              rdfs:label "Collaboration Relationship"@en ;
                              skos:definition "A social relationship in which agents work together toward a shared purpose. It may be dyadic or higher-order."@en ;
                              skos:prefLabel "Collaboration Relationship"@en .


###  https://www.michaeldebellis.com/social_network/Collaborator_Participation
sn:Collaborator_Participation rdf:type owl:Class ;
                              owl:equivalentClass [ owl:intersectionOf ( sn:Relationship_Participation
                                                                         [ rdf:type owl:Restriction ;
                                                                           owl:onProperty prov:hadRole ;
                                                                           owl:hasValue sn:Collaborator_Role
                                                                         ]
                                                                       ) ;
                                                    rdf:type owl:Class
                                                  ] ;
                              rdfs:isDefinedBy <https://www.michaeldebellis.com/social_network> ;
                              rdfs:label "Collaborator Participation"@en ;
                              skos:definition "A relationship participation in which the agent holds the Collaborator Role."@en ;
                              skos:prefLabel "Collaborator Participation"@en .


###  https://www.michaeldebellis.com/social_network/Community_Organizer
sn:Community_Organizer rdf:type owl:Class ;
                       rdfs:subClassOf sn:Person_Classified_By_Practice ;
                       rdfs:isDefinedBy <https://www.michaeldebellis.com/social_network> ;
                       rdfs:label "Community Organizer"@en ;
                       skos:definition "A person engaged in helping communities coordinate collective goals and action."@en ;
                       skos:prefLabel "Community Organizer"@en .


###  https://www.michaeldebellis.com/social_network/Dyadic_Social_Relationship
sn:Dyadic_Social_Relationship rdf:type owl:Class ;
                              owl:equivalentClass [ owl:intersectionOf ( sn:Social_Relationship
                                                                         [ rdf:type owl:Restriction ;
                                                                           owl:onProperty sn:has_relationship_participation ;
                                                                           owl:qualifiedCardinality "2"^^xsd:nonNegativeInteger ;
                                                                           owl:onClass sn:Relationship_Participation
                                                                         ]
                                                                       ) ;
                                                    rdf:type owl:Class
                                                  ] ;
                              rdfs:isDefinedBy <https://www.michaeldebellis.com/social_network> ;
                              rdfs:label "Dyadic Social Relationship"@en ;
                              skos:definition "A social relationship with exactly two qualified participations."@en ;
                              skos:prefLabel "Dyadic Social Relationship"@en .


###  https://www.michaeldebellis.com/social_network/Educator
sn:Educator rdf:type owl:Class ;
            rdfs:subClassOf sn:Person_Classified_By_Practice ;
            rdfs:isDefinedBy <https://www.michaeldebellis.com/social_network> ;
            rdfs:label "Educator"@en ;
            skos:definition "A person engaged in teaching, facilitation of learning, or educational support as a sustained practice."@en ;
            skos:prefLabel "Educator"@en .


###  https://www.michaeldebellis.com/social_network/Expertise
sn:Expertise rdf:type owl:Class ;
             rdfs:subClassOf prov:Entity ,
                             sulo:Capability ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty sn:has_expertise_subject ;
                               owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                               owl:onClass sulo:Object
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty sn:is_expertise_of ;
                               owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                               owl:onClass prov:Agent
                             ] ;
             rdfs:isDefinedBy <https://www.michaeldebellis.com/social_network> ;
             rdfs:label "Expertise"@en ;
             skos:definition "A first-class capability representing knowledge or skill possessed by an agent concerning one or more subjects."@en ;
             skos:prefLabel "Expertise"@en ;
             skos:scopeNote "Expertise is kept separate from the Scientist class. Children, community members, educators, scientists, and other participants may all possess expertise."@en .


###  https://www.michaeldebellis.com/social_network/Facilitation_Relationship
sn:Facilitation_Relationship rdf:type owl:Class ;
                             rdfs:subClassOf sn:Social_Relationship ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty sn:has_relationship_participation ;
                                               owl:someValuesFrom sn:Facilitator_Participation
                                             ] ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty sn:has_relationship_participation ;
                                               owl:someValuesFrom sn:Participant_Participation
                                             ] ;
                             rdfs:isDefinedBy <https://www.michaeldebellis.com/social_network> ;
                             rdfs:label "Facilitation Relationship"@en ;
                             skos:definition "A social relationship containing at least one Facilitator Participation and at least one general Participant Participation."@en ;
                             skos:prefLabel "Facilitation Relationship"@en .


###  https://www.michaeldebellis.com/social_network/Facilitator_Participation
sn:Facilitator_Participation rdf:type owl:Class ;
                             owl:equivalentClass [ owl:intersectionOf ( sn:Relationship_Participation
                                                                        [ rdf:type owl:Restriction ;
                                                                          owl:onProperty prov:hadRole ;
                                                                          owl:hasValue sn:Facilitator_Role
                                                                        ]
